# =============================================================================
# .env.example — Bookstore Demo
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Find these in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Public URL for your Supabase project (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key — used by the browser client (subject to RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Secret key — server-side only, bypasses RLS. NEVER expose to the browser.
SUPABASE_SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------

# Base URL of the application (used for absolute redirects and metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cookie
# -----------------------------------------------------------------------------

# Name of the cookie used to persist the current user selection
CURRENT_USER_COOKIE_NAME=bookstore_current_user
